# ═══════════════════════════════════════════════════════
# ChatGuard — Fichier de configuration d'environnement
# Copiez ce fichier en .env et remplissez vos valeurs
# ═══════════════════════════════════════════════════════

# ── Provider LLM ────────────────────────────────────────
# Valeurs possibles : openai | groq | huggingface | mock
LLM_MODEL=groq/compound-mini

# ── OpenAI ──────────────────────────────────────────────
# (optionnel, uniquement si LLM_PROVIDER=openai)
OPENAI_API_KEY=sk-...votre_clé_openai_ici...
LLM_MODEL=llama-3.1-8b-instant

# ── Groq ────────────────────────────────────────────────
# (optionnel, uniquement si LLM_PROVIDER=groq)
GROQ_API_KEY=

# ── HuggingFace Inference API ───────────────────────────
# (optionnel, uniquement si LLM_PROVIDER=huggingface)
HUGGINGFACE_API_TOKEN=hf_...votre_token_ici...
HF_MODEL_ID=mistralai/Mistral-7B-Instruct-v0.2

# ── Génération ──────────────────────────────────────────
N_GENERATIONS=3
TEMPERATURE=0.7
MAX_TOKENS=400

# ── Scoring ─────────────────────────────────────────────
# alpha = poids de l'incohérence interne dans le score final
# beta  = poids du risque heuristique dans le score final
# Si alpha + beta = 1.0 → formule normalisée (recommandé)
ALPHA=0.4
BETA=0.6

# Seuils de classification du risque
THRESHOLD_LOW=33
THRESHOLD_HIGH=67

# ── Embeddings ──────────────────────────────────────────
# Modèle sentence-transformers pour l'analyse de cohérence
# Autres options : paraphrase-multilingual-MiniLM-L12-v2
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ── Logs ────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=chatguard.log